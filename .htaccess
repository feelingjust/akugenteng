##################################################
#
# DO NOT EDIT THIS FILE
#
# Create a new .htaccess file in your htdocs
# directory (or example.com/htdocs/ directory)
# to add your own rules or override these rules.
#
##################################################

<IfModule mod_headers.c>
Header set Link '<https://malasid.github.io/favicon.png>; rel="icon"'
</IfModule>

# mod_rewrite starts here

RewriteEngine on

# does not apply to existing directories, meaning that if the folder exists on the server then don't change anything and don't run the Rule!

RewriteCond %{REQUEST_FILENAME} !-d

# Check for file in directory with .html extension.

RewriteCond %{REQUEST_FILENAME}\.html -f

# Here we actually show the page that has the .html extension

RewriteRule ^(.*)$ $1.html [NC,L]

# 404 Error

ErrorDocument 403 /error/403.html
ErrorDocument 404 /error/404.html
ErrorDocument 500 /error/500.html

# Anti hotlink

RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !https://sarviola.my.id [NC]
RewriteRule \.(jpg|png|css|js)$ - [F]